{
  "name": "overnight-agent",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "release:verify": "pnpm -r typecheck && pnpm -r lint && pnpm -r build && pnpm -r test",
    "release:dry-run": "pnpm -r publish --access public --dry-run",
    "release:publish": "pnpm -r publish --access public",
    "release": "pnpm run release:verify && pnpm run release:publish",
    "version:patch": "pnpm -r exec npm version patch --no-git-tag-version",
    "version:minor": "pnpm -r exec npm version minor --no-git-tag-version",
    "version:major": "pnpm -r exec npm version major --no-git-tag-version"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@types/node": "~22.12.0",
    "@typescript-eslint/eslint-plugin": "~8.58.0",
    "@typescript-eslint/parser": "~8.58.0",
    "@vitest/coverage-v8": "~4.1.0",
    "eslint": "~8.57.0",
    "prettier": "~3.8.0",
    "tsx": "~4.21.0",
    "typescript": "~6.0.0",
    "vitest": "~4.1.0"
  }
}
