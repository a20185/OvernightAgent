{
  "name": "@soulerou/oa-core",
  "version": "0.4.2",
  "description": "Core engine for OvernightAgent — schemas, worktree manager, four-gate verify pipeline, supervisor, events, and SUMMARY renderer.",
  "keywords": [
    "overnight-agent",
    "oa",
    "agent",
    "supervisor",
    "worktree",
    "claude",
    "codex",
    "opencode"
  ],
  "author": "Souler Ou",
  "license": "MIT",
  "homepage": "https://github.com/a20185/OvernightAgent#readme",
  "bugs": {
    "url": "https://github.com/a20185/OvernightAgent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a20185/OvernightAgent.git",
    "directory": "packages/oa-core"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
